# ── PlantMD Backend — environment variables ───────────────────────────────────
# Copy this file to .env and fill in values before starting.

# Port this Express server listens on
PORT=5000

# URL of the FastAPI AI inference server
AI_SERVER=http://localhost:8000

# CORS allowed origins (* allows all; use specific origin in production)
CORS_ORIGIN=http://localhost:3000

# Node environment: development | production
NODE_ENV=development
