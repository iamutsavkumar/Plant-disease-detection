# ── PlantMD AI Server — environment variables ─────────────────────────────────
# Copy this file to .env and fill in values before starting.

# Port the FastAPI server listens on
PORT=8000

# Allowed CORS origins (comma-separated or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Path to the trained Keras model file (relative to ai-server/)
MODEL_PATH=model/plantmd_model.keras

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
